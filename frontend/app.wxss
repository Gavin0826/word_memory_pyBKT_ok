/* ========================================
   全局设计系统 - 深邃墨蓝 × 金橙渐变主题
   ======================================== */

page {
  --color-primary: #1a2744;
  --color-primary-light: #253660;
  --color-accent: #f5a623;
  --color-accent-light: #f7c05a;
  --color-accent-dark: #e08c0a;
  --color-success: #3ecf8e;
  --color-danger: #ff5c5c;
  --color-bg: #f0f3f9;
  --color-card: #ffffff;
  --color-text-primary: #1a2744;
  --color-text-secondary: #5a6a8a;
  --color-text-muted: #a0aec0;
  --color-border: #e2e8f2;
  --grad-primary: linear-gradient(135deg, #1a2744 0%, #2d4a8a 100%);
  --grad-accent: linear-gradient(135deg, #f5a623 0%, #f7c05a 100%);
  --grad-card: linear-gradient(135deg, #253660 0%, #1a2744 100%);
  --grad-success: linear-gradient(135deg, #3ecf8e 0%, #2bb577 100%);
  --grad-danger: linear-gradient(135deg, #ff5c5c 0%, #ff8c5c 100%);
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 32rpx;
  --radius-xl: 48rpx;
  --shadow-sm: 0 4rpx 16rpx rgba(26, 39, 68, 0.08);
  --shadow-md: 0 8rpx 32rpx rgba(26, 39, 68, 0.12);
  --shadow-lg: 0 16rpx 48rpx rgba(26, 39, 68, 0.18);
  --shadow-accent: 0 8rpx 24rpx rgba(245, 166, 35, 0.35);
  background-color: var(--color-bg);
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: var(--color-text-primary);
}

.container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding: 0;
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
}

/* 通用按钮 */
.btn-primary {
  background: var(--grad-accent);
  color: #1a2744;
  font-weight: 700;
  border-radius: var(--radius-xl);
  border: none;
  box-shadow: var(--shadow-accent);
  font-size: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
}

.btn-secondary {
  background: transparent;
  color: var(--color-primary);
  font-weight: 600;
  border-radius: var(--radius-xl);
  border: 2rpx solid var(--color-border);
  font-size: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
}

/* 加载动画 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
}

.loading text {
  color: var(--color-text-muted);
  font-size: 28rpx;
  margin-top: 20rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid var(--color-border);
  border-top-color: var(--color-accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
