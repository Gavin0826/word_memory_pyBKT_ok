<!-- pages/admin-user-list/admin-user-list.wxml -->
<view class="container">
  <view class="header">
    <view class="header-back" bindtap="goBack"><text>‹ 返回</text></view>
    <text class="header-title">用户列表</text>
    <view style="width:80rpx"></view>
  </view>
  <view class="summary-bar">
    <text class="summary-text">共 {{users.length}} 名注册用户</text>
  </view>
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>
  <view class="user-list" wx:if="{{!loading}}">
    <view class="user-item" wx:for="{{users}}" wx:key="id" bindtap="goToStats" data-user="{{item}}">
      <view class="user-avatar"><text>{{item.username[0]}}</text></view>
      <view class="user-info">
        <text class="user-name">{{item.username}}</text>
        <text class="user-email">{{item.email || '未设置邮箱'}}</text>
        <text class="user-meta">已学 {{item.totalWords}} 词 · {{item.studiedDays}} 天</text>
      </view>
      <view class="user-right">
        <text class="user-words">{{item.totalWords}}</text>
        <text class="user-words-lab">单词</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>
  <view class="empty-tip" wx:if="{{!loading && users.length === 0}}">
    <text class="empty-icon">👥</text>
    <text class="empty-text">暂无用户</text>
  </view>
</view>
