/* pages/admin-user-stats/admin-user-stats.wxss */
.container { min-height: 100vh; background: #f4f5f7; padding-bottom: 60rpx; }
.header { background: linear-gradient(135deg, #FF6B35, #FF8C42); padding: 80rpx 30rpx 30rpx; display: flex; align-items: center; justify-content: space-between; }
.header-back text { font-size: 30rpx; color: white; }
.header-title { font-size: 30rpx; font-weight: bold; color: white; flex: 1; text-align: center; }
.loading-wrap { display: flex; flex-direction: column; align-items: center; padding: 60rpx; gap: 20rpx; }
.loading-spinner { width: 60rpx; height: 60rpx; border: 6rpx solid #f3f3f3; border-top: 6rpx solid #FF6B35; border-radius: 50%; animation: spin 1s linear infinite; }
@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
.user-card { background: white; margin: 24rpx; border-radius: 20rpx; padding: 30rpx; display: flex; align-items: center; gap: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06); }
.user-avatar { width: 100rpx; height: 100rpx; background: linear-gradient(135deg, #FF6B35, #FF8C42); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.user-avatar text { font-size: 44rpx; color: white; font-weight: bold; }
.user-detail { flex: 1; }
.user-name { font-size: 34rpx; font-weight: bold; color: #222; display: block; margin-bottom: 8rpx; }
.user-email { font-size: 24rpx; color: #999; display: block; margin-bottom: 6rpx; }
.user-join { font-size: 22rpx; color: #bbb; display: block; }
.stats-grid { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 0 24rpx 10rpx; }
.stat-item { flex: 1; min-width: 140rpx; background: white; border-radius: 16rpx; padding: 24rpx 16rpx; text-align: center; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05); }
.stat-val { font-size: 44rpx; font-weight: bold; display: block; margin-bottom: 8rpx; }
.stat-val.orange { color: #FF6B35; }
.stat-val.green { color: #4CAF50; }
.stat-val.blue { color: #2196F3; }
.stat-val.purple { color: #9C27B0; }
.stat-lab { font-size: 22rpx; color: #999; display: block; }
.section-title { font-size: 26rpx; color: #999; padding: 20rpx 30rpx 10rpx; font-weight: bold; }
.progress-card { background: white; margin: 0 24rpx; border-radius: 16rpx; padding: 30rpx; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05); }
.progress-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.progress-label { font-size: 28rpx; font-weight: bold; color: #333; }
.progress-count { font-size: 24rpx; color: #999; }
.progress-bar-bg { height: 16rpx; background: #f0f0f0; border-radius: 8rpx; overflow: hidden; }
.progress-bar-fill { height: 100%; border-radius: 8rpx; transition: width 0.3s; }
.progress-bar-fill.orange { background: linear-gradient(90deg, #FF6B35, #FF8C42); }
.progress-bar-fill.blue { background: linear-gradient(90deg, #2196F3, #42A5F5); }
.records-list { margin: 0 24rpx; background: white; border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05); }
.record-item { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 24rpx; border-bottom: 1rpx solid #f5f5f5; }
.record-item:last-child { border-bottom: none; }
.record-word { flex: 1; }
.rw-text { font-size: 30rpx; font-weight: bold; color: #333; display: block; }
.rw-cat { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.record-result { width: 56rpx; height: 56rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.record-result.correct { background: #E8F5E9; color: #4CAF50; font-size: 30rpx; }
.record-result.wrong { background: #FFEBEE; color: #F44336; font-size: 30rpx; }
.empty-tip { padding: 40rpx; text-align: center; }
.empty-text { font-size: 28rpx; color: #999; }
