<!-- pages/admin-wordlist/admin-wordlist.wxml -->
<view class="container">
  <view class="header">
    <view class="header-back" bindtap="goBack"><text>‹ 返回</text></view>
    <text class="header-title">词库管理</text>
    <view class="header-action" bindtap="goToAddWord"><text>+ 添加</text></view>
  </view>

  <view class="stats-row">
    <view class="stat-card">
      <text class="stat-val">{{categories.length}}</text>
      <text class="stat-lab">词库数量</text>
    </view>
    <view class="stat-card">
      <text class="stat-val">{{totalWords}}</text>
      <text class="stat-lab">总单词数</text>
    </view>
  </view>

  <view class="section-title">全部词库（点击进入编辑）</view>

  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <view class="wordlist-group" wx:if="{{!loading}}">
    <view class="wordlist-item" wx:for="{{categories}}" wx:key="id"
      bindtap="goToWordList" data-category="{{item.id}}" data-name="{{item.name}}">
      <view class="wordlist-icon-wrap"><text class="wordlist-icon">📖</text></view>
      <view class="wordlist-info">
        <text class="wordlist-name">{{item.name}}</text>
        <text class="wordlist-meta">{{item.desc}}</text>
      </view>
      <view class="wordlist-right">
        <text class="word-count-badge">{{item.count}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="empty-tip" wx:if="{{!loading && categories.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无词库数据</text>
  </view>
</view>
