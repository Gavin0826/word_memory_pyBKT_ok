/* pages/admin-wordlist/admin-wordlist.wxss */
.container { min-height: 100vh; background: #f4f5f7; padding-bottom: 60rpx; }
.header { background: linear-gradient(135deg, #FF6B35, #FF8C42); padding: 80rpx 30rpx 30rpx; display: flex; align-items: center; justify-content: space-between; }
.header-back text, .header-action text { font-size: 30rpx; color: white; }
.header-action { padding: 10rpx 20rpx; background: rgba(255,255,255,0.2); border-radius: 20rpx; }
.header-title { font-size: 36rpx; font-weight: bold; color: white; flex: 1; text-align: center; }
.stats-row { display: flex; gap: 20rpx; padding: 24rpx; }
.stat-card { flex: 1; background: white; border-radius: 16rpx; padding: 30rpx; text-align: center; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06); }
.stat-val { font-size: 52rpx; font-weight: bold; color: #FF6B35; display: block; margin-bottom: 8rpx; }
.stat-lab { font-size: 24rpx; color: #999; display: block; }
.section-title { font-size: 26rpx; color: #999; padding: 10rpx 30rpx 16rpx; font-weight: bold; letter-spacing: 2rpx; }
.wordlist-group { background: white; margin: 0 24rpx; border-radius: 20rpx; overflow: hidden; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05); }
.wordlist-item { display: flex; align-items: center; padding: 28rpx 24rpx; gap: 20rpx; border-bottom: 1rpx solid #f5f5f5; }
.wordlist-item:last-child { border-bottom: none; }
.wordlist-icon-wrap { width: 80rpx; height: 80rpx; background: #FFF3EE; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.wordlist-icon { font-size: 40rpx; }
.wordlist-info { flex: 1; min-width: 0; }
.wordlist-name { font-size: 32rpx; font-weight: bold; color: #333; display: block; margin-bottom: 8rpx; }
.wordlist-meta { font-size: 24rpx; color: #999; display: block; }
.wordlist-right { display: flex; align-items: center; gap: 10rpx; flex-shrink: 0; }
.word-count-badge { background: #FF6B35; color: white; font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 20rpx; font-weight: bold; }
.menu-arrow { font-size: 40rpx; color: #ccc; }
.empty-tip { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 20rpx; }
.empty-icon { font-size: 100rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.loading-wrap { display: flex; flex-direction: column; align-items: center; padding: 60rpx; gap: 20rpx; }
.loading-spinner { width: 60rpx; height: 60rpx; border: 6rpx solid #f3f3f3; border-top: 6rpx solid #FF6B35; border-radius: 50%; animation: spin 1s linear infinite; }
@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
