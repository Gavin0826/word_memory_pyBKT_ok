<!-- pages/admin/admin.wxml -->
<view class="container">

  <!-- 顶部导航栏 -->
  <view class="navbar">
    <view class="navbar-left">
      <text class="navbar-icon">🔐</text>
      <text class="navbar-title">管理后台</text>
    </view>
    <view class="navbar-right" bindtap="confirmLogout">
      <text class="logout-text">退出</text>
    </view>
  </view>

  <!-- 管理员信息卡片 -->
  <view class="admin-card">
    <view class="admin-avatar">
      <text>👤</text>
    </view>
    <view class="admin-info">
      <text class="admin-name">系统管理员</text>
      <text class="admin-role">超级管理员 · 完全权限</text>
    </view>
    <view class="admin-status">
      <text class="status-dot"></text>
      <text class="status-text">在线</text>
    </view>
  </view>

  <!-- 功能模块列表 -->
  <view class="section-title">词库管理</view>

  <view class="menu-group">
    <view class="menu-item" bindtap="goToWordlistManage">
      <view class="menu-icon-wrap" style="background:#E3F2FD">
        <text class="menu-icon">📚</text>
      </view>
      <view class="menu-content">
        <text class="menu-label">词库列表</text>
        <text class="menu-desc">查看和管理所有词库</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToAddWord">
      <view class="menu-icon-wrap" style="background:#E8F5E9">
        <text class="menu-icon">➕</text>
      </view>
      <view class="menu-content">
        <text class="menu-label">添加单词</text>
        <text class="menu-desc">向指定词库添加新单词</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToEditWord">
      <view class="menu-icon-wrap" style="background:#FFF3E0">
        <text class="menu-icon">✏️</text>
      </view>
      <view class="menu-content">
        <text class="menu-label">编辑单词</text>
        <text class="menu-desc">修改或删除现有单词</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToImportWord">
      <view class="menu-icon-wrap" style="background:#F3E5F5">
        <text class="menu-icon">📥</text>
      </view>
      <view class="menu-content">
        <text class="menu-label">批量导入</text>
        <text class="menu-desc">通过JSON文件批量导入单词</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="section-title">用户管理</view>

  <view class="menu-group">
    <view class="menu-item" bindtap="goToUserList">
      <view class="menu-icon-wrap" style="background:#E0F7FA">
        <text class="menu-icon">👥</text>
      </view>
      <view class="menu-content">
        <text class="menu-label">用户列表</text>
        <text class="menu-desc">查看所有注册用户</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToUserStats">
      <view class="menu-icon-wrap" style="background:#FCE4EC">
        <text class="menu-icon">📊</text>
      </view>
      <view class="menu-content">
        <text class="menu-label">学习统计</text>
        <text class="menu-desc">查看用户学习数据统计</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="section-title">系统设置</view>

  <view class="menu-group">
    <view class="menu-item" bindtap="goToSystemSettings">
      <view class="menu-icon-wrap" style="background:#EFEBE9">
        <text class="menu-icon">⚙️</text>
      </view>
      <view class="menu-content">
        <text class="menu-label">系统参数</text>
        <text class="menu-desc">配置系统运行参数</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToBackup">
      <view class="menu-icon-wrap" style="background:#E8EAF6">
        <text class="menu-icon">💾</text>
      </view>
      <view class="menu-content">
        <text class="menu-label">数据备份</text>
        <text class="menu-desc">备份和恢复系统数据</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 开发中提示 -->
  <view class="dev-notice">
    <text class="dev-notice-icon">🚧</text>
    <text class="dev-notice-text">部分功能正在开发中，敬请期待</text>
  </view>

  <!-- 退出按钮 -->
  <button class="btn-logout" bindtap="confirmLogout">退出管理后台</button>

</view>
