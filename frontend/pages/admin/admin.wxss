/* pages/admin/admin.wxss */

.container {
  min-height: 100vh;
  background-color: #f4f5f7;
  padding-bottom: 60rpx;
}

/* ========== 导航栏 ========== */
.navbar {
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  padding: 80rpx 30rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.navbar-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.navbar-icon {
  font-size: 44rpx;
}

.navbar-title {
  font-size: 40rpx;
  font-weight: bold;
  color: white;
}

.navbar-right {
  padding: 12rpx 28rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 30rpx;
}

.logout-text {
  font-size: 28rpx;
  color: white;
}

/* ========== 管理员信息卡片 ========== */
.admin-card {
  background: white;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.admin-avatar {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  flex-shrink: 0;
}

.admin-info {
  flex: 1;
}

.admin-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.admin-role {
  font-size: 24rpx;
  color: #FF6B35;
  display: block;
}

.admin-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  background: #4CAF50;
  border-radius: 50%;
  display: block;
}

.status-text {
  font-size: 24rpx;
  color: #4CAF50;
}

/* ========== 分组标题 ========== */
.section-title {
  font-size: 26rpx;
  color: #999;
  padding: 30rpx 30rpx 16rpx;
  letter-spacing: 2rpx;
  font-weight: bold;
}

/* ========== 菜单组 ========== */
.menu-group {
  background: white;
  margin: 0 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  margin-bottom: 8rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  gap: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #fafafa;
}

.menu-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon {
  font-size: 40rpx;
}

.menu-content {
  flex: 1;
}

.menu-label {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 6rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.menu-arrow {
  font-size: 40rpx;
  color: #ccc;
  line-height: 1;
}

/* ========== 开发中提示 ========== */
.dev-notice {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin: 30rpx 24rpx;
  padding: 24rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
  border: 1rpx solid #FFE082;
}

.dev-notice-icon {
  font-size: 32rpx;
}

.dev-notice-text {
  font-size: 26rpx;
  color: #F57C00;
}

/* ========== 退出按钮 ========== */
.btn-logout {
  margin: 10rpx 24rpx 0;
  background: white;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
  border-radius: 16rpx;
  height: 96rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-logout:active {
  background: #FFF3EE;
}
