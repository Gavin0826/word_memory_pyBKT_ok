/* pages/favorites/favorites.wxss */

.container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 60rpx;
}

/* Header */
.header {
  background: var(--grad-card);
  padding: 70rpx 40rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -80rpx; right: -60rpx;
  width: 320rpx; height: 320rpx;
  border-radius: 50%;
  background: rgba(245,166,35,0.08);
}

.header-inner {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  position: relative; z-index: 1;
}

.header-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
  letter-spacing: 3rpx;
  display: block;
  margin-bottom: 10rpx;
}

.header-title {
  font-size: 56rpx;
  font-weight: 900;
  color: #ffffff;
  display: block;
}

.header-badge {
  background: var(--grad-accent);
  border-radius: var(--radius-lg);
  padding: 16rpx 24rpx;
  text-align: center;
  box-shadow: var(--shadow-accent);
}

.badge-num {
  font-size: 44rpx;
  font-weight: 900;
  color: #1a2744;
  display: block;
  line-height: 1;
}

.badge-label {
  font-size: 20rpx;
  color: #1a2744;
  opacity: 0.7;
  display: block;
}

/* 列表 */
.list-section {
  padding: 24rpx 32rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.word-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  position: relative;
  overflow: hidden;
}

.word-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 8rpx;
  background: var(--grad-accent);
  border-radius: 0 4rpx 4rpx 0;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
}

.word-info { flex: 1; }

.word-text {
  font-size: 44rpx;
  font-weight: 900;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.word-pron {
  font-size: 26rpx;
  color: var(--color-accent);
  font-style: italic;
  display: block;
}

.card-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.category-tag {
  background: rgba(26,39,68,0.06);
  color: var(--color-text-muted);
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  letter-spacing: 1rpx;
}

.star-btn {
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(245,166,35,0.1);
  transition: all 0.2s;
}

.star-btn.active { background: rgba(245,166,35,0.15); }

.star-icon {
  font-size: 40rpx;
  color: rgba(200,200,200,0.8);
  line-height: 1;
}

.star-btn.active .star-icon {
  color: var(--color-accent);
}

.card-bottom { padding-left: 16rpx; }

.word-meaning {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
  line-height: 1.5;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  color: var(--color-text-muted);
  display: block;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--color-text-muted);
  display: block;
  margin-bottom: 60rpx;
  line-height: 1.6;
}

.btn-go-study {
  width: 60%;
  height: 96rpx;
  background: var(--grad-accent) !important;
  color: #1a2744 !important;
  font-size: 30rpx;
  font-weight: 800;
  border-radius: var(--radius-xl) !important;
  border: none !important;
  box-shadow: var(--shadow-accent);
}

.btn-go-study::after { border: none !important; }

/* 加载 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx;
}

.loading text {
  color: var(--color-text-muted);
  font-size: 28rpx;
  margin-top: 24rpx;
}

.loading-spinner {
  width: 80rpx; height: 80rpx;
  border: 6rpx solid var(--color-border);
  border-top-color: var(--color-accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }
