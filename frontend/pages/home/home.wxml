<!-- pages/home/home.wxml -->
<view class="container">

  <!-- 顶部英雄区域 -->
  <view class="hero-section" wx:if="{{userInfo}}">
    <view class="user-greeting">
      <view class="greeting-left">
        <text class="greeting-hi">WELCOME BACK</text>
        <text class="greeting-name">{{userInfo.username}}</text>
      </view>
      <view class="streak-badge">
        <text class="streak-num">{{userInfo.studiedDays || 0}}</text>
        <text class="streak-label">连续天数</text>
      </view>
    </view>
    <view class="stats-row">
      <view class="stat-block">
        <text class="stat-num">{{userInfo.totalWords || 0}}</text>
        <text class="stat-lbl">已学单词</text>
      </view>
      <view class="stat-block">
        <text class="stat-num">{{todayTask.newCount || 0}}</text>
        <text class="stat-lbl">今日新词</text>
      </view>
      <view class="stat-block">
        <text class="stat-num">{{reviewCount}}</text>
        <text class="stat-lbl">待复习</text>
      </view>
    </view>
  </view>

  <!-- 主内容区 -->
  <view class="main-content" wx:if="{{userInfo}}">
    <text class="section-title">TODAY'S PLAN</text>

    <!-- 今日学习入口 -->
    <view class="cta-card cta-study" bindtap="goToStudy">
      <view class="cta-text-wrap">
        <text class="cta-main">开始学习</text>
        <text class="cta-sub">今日新词 {{todayTask.newCount || 0}} 个待学习</text>
      </view>
      <text class="cta-arrow">›</text>
    </view>

    <!-- 复习入口 -->
    <view class="cta-card cta-review" bindtap="goToReview">
      <view class="cta-text-wrap">
        <text class="cta-main">开始复习</text>
        <text class="cta-sub">
          <text wx:if="{{loadingReviewCount}}">加载中...</text>
          <text wx:elif="{{reviewCount > 0}}">{{reviewCount}} 个单词等待复习</text>
          <text wx:else>今日复习已完成 🎉</text>
        </text>
      </view>
      <text class="cta-arrow">›</text>
    </view>

    <text class="section-title">STATS</text>

    <!-- 任务详情卡片 -->
    <view class="task-card" bindtap="goToStudy">
      <view class="task-info">
        <text class="task-label">今日学习</text>
        <text class="task-title">新词任务</text>
        <text class="task-meta">艾宾浩斯记忆曲线安排</text>
      </view>
      <view class="task-badge">
        <text class="badge-num">{{todayTask.newCount || 0}}</text>
        <text class="badge-unit">个新词</text>
      </view>
    </view>

    <view class="task-card review-card" bindtap="goToReview">
      <view class="task-info">
        <text class="task-label">复习计划</text>
        <text class="task-title">待复习单词</text>
        <text class="task-meta">巩固已学词汇</text>
      </view>
      <view class="task-badge">
        <text class="badge-num green">{{reviewCount}}</text>
        <text class="badge-unit">待复习</text>
      </view>
    </view>
  </view>

  <!-- 未登录提示 -->
  <view class="login-prompt" wx:if="{{!userInfo}}">
    <text>请先登录以查看学习计划</text>
    <button type="primary" bindtap="goToLogin">登录 / 注册</button>
  </view>

</view>
