/* ==============================
   首页样式 - 深邃墨蓝 × 金橙主题
   ============================== */

.container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 40rpx;
}

/* 顶部英雄区域 */
.hero-section {
  background: var(--grad-card);
  padding: 80rpx 40rpx 60rpx;
  position: relative;
  overflow: hidden;
}

.hero-section::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -80rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(245, 166, 35, 0.08);
}

.hero-section::after {
  content: '';
  position: absolute;
  bottom: -60rpx;
  left: -60rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(62, 207, 142, 0.06);
}

.user-greeting {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 50rpx;
  position: relative;
  z-index: 1;
}

.greeting-left {}

.greeting-hi {
  font-size: 30rpx;
  color: rgba(255,255,255,0.6);
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.greeting-name {
  font-size: 52rpx;
  font-weight: 800;
  color: #ffffff;
  display: block;
  letter-spacing: 1rpx;
}

.streak-badge {
  background: var(--grad-accent);
  border-radius: var(--radius-lg);
  padding: 16rpx 24rpx;
  text-align: center;
  box-shadow: var(--shadow-accent);
}

.streak-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a2744;
  display: block;
  line-height: 1;
}

.streak-label {
  font-size: 20rpx;
  color: #1a2744;
  opacity: 0.7;
  display: block;
  margin-top: 4rpx;
}

/* 统计数据行 */
.stats-row {
  display: flex;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.stat-block {
  flex: 1;
  text-align: center;
  border-right: 2rpx solid rgba(255,255,255,0.1);
}

.stat-block:last-child {
  border-right: none;
}

.stat-num {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--color-accent);
  display: block;
  line-height: 1;
  margin-bottom: 10rpx;
}

.stat-lbl {
  font-size: 22rpx;
  color: rgba(255,255,255,0.55);
  display: block;
  letter-spacing: 1rpx;
}

/* 主要内容区域 */
.main-content {
  padding: 32rpx 32rpx 0;
}

.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text-muted);
  letter-spacing: 3rpx;
  text-transform: uppercase;
  margin-bottom: 20rpx;
  margin-top: 8rpx;
}

/* 今日任务卡片 */
.task-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
}

.task-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: var(--grad-accent);
  border-radius: 0 4rpx 4rpx 0;
}

.task-card.review-card::before {
  background: var(--grad-success);
}

.task-info {}

.task-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.task-title {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 12rpx;
}

.task-meta {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.task-badge {
  min-width: 120rpx;
  text-align: center;
  flex-shrink: 0;
}

.badge-num {
  font-size: 64rpx;
  font-weight: 800;
  color: var(--color-accent);
  display: block;
  line-height: 1;
}

.badge-unit {
  font-size: 22rpx;
  color: var(--color-text-muted);
  display: block;
  margin-top: 6rpx;
}

.badge-num.green {
  color: var(--color-success);
}

/* 开始按钮卡片 */
.cta-card {
  border-radius: var(--radius-lg);
  padding: 40rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: var(--shadow-accent);
}

.cta-study {
  background: var(--grad-accent);
}

.cta-review {
  background: var(--grad-success);
}

.cta-text-wrap {}

.cta-main {
  font-size: 38rpx;
  font-weight: 800;
  color: #1a2744;
  display: block;
  margin-bottom: 8rpx;
}

.cta-sub {
  font-size: 24rpx;
  color: rgba(26,39,68,0.65);
}

.cta-arrow {
  font-size: 56rpx;
  color: rgba(26,39,68,0.4);
  font-weight: 300;
}

/* 旧样式兼容保留 */
.user-section {
  background: var(--grad-card);
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
  padding: 80rpx 40rpx 50rpx;
  color: white;
  margin-bottom: 0;
}

.login-prompt {
  text-align: center;
  padding: 120rpx 40rpx;
}

.login-prompt text {
  display: block;
  margin-bottom: 40rpx;
  color: var(--color-text-secondary);
  font-size: 32rpx;
}

.login-prompt button {
  background: var(--grad-accent);
  color: #1a2744;
  font-weight: 700;
  border-radius: var(--radius-xl);
  border: none;
  box-shadow: var(--shadow-accent);
}
