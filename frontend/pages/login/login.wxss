/* ==============================
   登录页样式
   ============================== */

.container {
  min-height: 100vh;
  background: var(--grad-primary);
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: absolute;
  top: -150rpx;
  right: -100rpx;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: rgba(245, 166, 35, 0.07);
}

.container::after {
  content: '';
  position: absolute;
  bottom: -100rpx;
  left: -80rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: rgba(62, 207, 142, 0.05);
}

/* Logo 区域 */
.logo {
  padding-top: 120rpx;
  padding-bottom: 64rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.logo-icon {
  font-size: 96rpx;
  display: block;
  margin-bottom: 20rpx;
}

.logo-text {
  font-size: 64rpx;
  font-weight: 900;
  color: #ffffff;
  display: block;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.logo-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
  display: block;
  letter-spacing: 3rpx;
}

/* 模式切换 Tab */
.mode-tabs {
  display: flex;
  background: rgba(255,255,255,0.08);
  border-radius: var(--radius-xl);
  padding: 6rpx;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 1;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: rgba(255,255,255,0.45);
  font-weight: 600;
  transition: all 0.2s;
}

.mode-tab.active {
  background: var(--grad-accent);
  color: #1a2744;
  font-weight: 800;
  box-shadow: var(--shadow-accent);
}

/* 表单 */
.form {
  position: relative;
  z-index: 1;
}

.input-group {
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 96rpx;
  background: rgba(255,255,255,0.10);
  border: 2rpx solid rgba(255,255,255,0.12);
  border-radius: var(--radius-lg);
  padding: 0 32rpx;
  font-size: 30rpx;
  color: #ffffff;
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.input::placeholder {
  color: rgba(255,255,255,0.3);
}

.input:focus {
  border-color: var(--color-accent);
  background: rgba(255,255,255,0.14);
}

.remember-me {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  color: rgba(255,255,255,0.5);
  font-size: 26rpx;
  gap: 12rpx;
}

.remember-me checkbox {
  margin-right: 8rpx;
}

/* 登录按钮 */
.btn-login {
  width: 100%;
  height: 100rpx;
  background: var(--grad-accent) !important;
  color: #1a2744 !important;
  font-size: 34rpx;
  font-weight: 800;
  border-radius: var(--radius-xl) !important;
  border: none !important;
  box-shadow: var(--shadow-accent);
  letter-spacing: 4rpx;
  margin-bottom: 32rpx;
}

.btn-login::after {
  border: none !important;
}

/* 管理员按钮 */
.btn-admin {
  background: rgba(255,255,255,0.12) !important;
  color: rgba(255,255,255,0.85) !important;
  box-shadow: none;
  border: 2rpx solid rgba(255,255,255,0.2) !important;
}

/* 链接 */
.links {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
}

.link {
  font-size: 28rpx;
  color: rgba(255,255,255,0.5);
}

.link-separator {
  color: rgba(255,255,255,0.2);
  font-size: 24rpx;
}

/* 管理员徽章 */
.admin-badge {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(245, 166, 35, 0.12);
  border: 2rpx solid rgba(245, 166, 35, 0.25);
  border-radius: var(--radius-lg);
  padding: 24rpx 32rpx;
  margin-bottom: 32rpx;
}

.admin-badge-icon {
  font-size: 40rpx;
}

.admin-badge-text {
  font-size: 26rpx;
  color: var(--color-accent);
  font-weight: 600;
  letter-spacing: 1rpx;
}

.admin-hint {
  text-align: center;
  margin-top: 20rpx;
}

.admin-hint text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.3);
  line-height: 1.6;
}

/* 底部 */
.footer {
  margin-top: auto;
  padding: 40rpx 0 60rpx;
  text-align: center;
  position: relative;
  z-index: 1;
}

.footer text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.2);
  letter-spacing: 1rpx;
}
