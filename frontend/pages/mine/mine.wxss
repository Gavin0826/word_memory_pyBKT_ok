/* ==============================
   我的页面样式
   ============================== */

.container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 60rpx;
}

/* 用户信息区域 */
.user-section {
  background: var(--grad-card);
  padding: 80rpx 40rpx 50rpx;
  position: relative;
  overflow: hidden;
}

.user-section::before {
  content: '';
  position: absolute;
  top: -80rpx; right: -60rpx;
  width: 340rpx; height: 340rpx;
  border-radius: 50%;
  background: rgba(245, 166, 35, 0.07);
}

.user-header {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 48rpx;
  position: relative;
  z-index: 1;
}

.user-avatar {
  width: 112rpx; height: 112rpx;
  border-radius: 50%;
  background: var(--grad-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-accent);
  flex-shrink: 0;
}

.avatar-text {
  font-size: 44rpx;
  font-weight: 900;
  color: #1a2744;
}

.username {
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
}

/* 统计网格 */
.stats-grid {
  display: flex;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.stat-item {
  flex: 1;
  text-align: center;
  border-right: 2rpx solid rgba(255,255,255,0.1);
}

.stat-item:last-child { border-right: none; }

.stat-value {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--color-accent);
  display: block;
  line-height: 1;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.45);
  display: block;
}

/* 功能列表 */
.function-list {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  margin: 24rpx 32rpx 0;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.list-title {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--color-text-muted);
  letter-spacing: 3rpx;
  padding: 28rpx 36rpx 16rpx;
  border-bottom: 2rpx solid var(--color-border);
}

.function-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx;
  border-bottom: 2rpx solid var(--color-border);
}

.function-item:last-child { border-bottom: none; }

.function-item:active { background: rgba(26,39,68,0.03); }

.function-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.function-icon { font-size: 40rpx; width: 56rpx; text-align: center; }

.function-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.function-badge {
  background: var(--color-danger);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
}

.function-tag {
  background: var(--color-accent);
  color: #1a2744;
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
}

.function-arrow {
  font-size: 40rpx;
  color: var(--color-text-muted);
  font-weight: 300;
}

/* 操作按钮区 */
.action-buttons {
  padding: 32rpx;
  margin-top: 8rpx;
}

.btn-logout {
  width: 100%;
  height: 96rpx;
  background: var(--grad-danger) !important;
  color: #ffffff !important;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: var(--radius-xl) !important;
  border: none !important;
  letter-spacing: 2rpx;
}

.btn-login {
  width: 100%;
  height: 96rpx;
  background: var(--grad-accent) !important;
  color: #1a2744 !important;
  font-size: 32rpx;
  font-weight: 800;
  border-radius: var(--radius-xl) !important;
  border: none !important;
  box-shadow: var(--shadow-accent);
}

.btn-logout::after, .btn-login::after { border: none !important; }

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 32rpx 0 16rpx;
}

.version-info text {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.8;
}

/* 加载 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: var(--color-text-muted);
  font-size: 28rpx;
}
