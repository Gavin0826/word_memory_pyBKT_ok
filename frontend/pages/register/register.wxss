/* ==============================
   注册页样式
   ============================== */

.container {
  min-height: 100vh;
  background: var(--grad-primary);
  padding: 0 48rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: absolute;
  top: -150rpx; right: -100rpx;
  width: 500rpx; height: 500rpx;
  border-radius: 50%;
  background: rgba(62,207,142,0.06);
}

.container::after {
  content: '';
  position: absolute;
  bottom: -100rpx; left: -80rpx;
  width: 360rpx; height: 360rpx;
  border-radius: 50%;
  background: rgba(245,166,35,0.05);
}

/* 头部 */
.header {
  padding-top: 100rpx;
  padding-bottom: 56rpx;
  position: relative; z-index: 1;
}

.title {
  font-size: 60rpx; font-weight: 900;
  color: #ffffff; display: block;
  margin-bottom: 12rpx; letter-spacing: 2rpx;
}

.subtitle {
  font-size: 26rpx; color: rgba(255,255,255,0.45);
  display: block; letter-spacing: 2rpx;
}

/* 表单 */
.form { position: relative; z-index: 1; }

.input-group { margin-bottom: 20rpx; }

.input {
  width: 100%; height: 96rpx;
  background: rgba(255,255,255,0.10);
  border: 2rpx solid rgba(255,255,255,0.12);
  border-radius: var(--radius-lg);
  padding: 0 32rpx;
  font-size: 30rpx; color: #ffffff;
  box-sizing: border-box;
}

.input::placeholder { color: rgba(255,255,255,0.3); }

.hint {
  font-size: 22rpx; color: rgba(255,255,255,0.3);
  display: block; margin-top: 10rpx;
  padding: 0 8rpx; line-height: 1.5;
}

/* 密码强度 */
.strength { margin-bottom: 24rpx; }

.strength text {
  font-size: 24rpx; color: rgba(255,255,255,0.5);
  display: block; margin-bottom: 12rpx;
}

.strength-bar {
  height: 8rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 8rpx; overflow: hidden;
}

.strength-level {
  height: 100%; border-radius: 8rpx;
  transition: width 0.3s ease;
}

.strength-level.weak { width: 33%; background: var(--color-danger); }
.strength-level.medium { width: 66%; background: var(--color-accent); }
.strength-level.strong { width: 100%; background: var(--color-success); }

/* 注册按钮 */
.btn-register {
  width: 100%; height: 100rpx;
  background: var(--grad-accent) !important;
  color: #1a2744 !important;
  font-size: 34rpx; font-weight: 800;
  border-radius: var(--radius-xl) !important;
  border: none !important;
  box-shadow: var(--shadow-accent);
  letter-spacing: 4rpx;
  margin-bottom: 32rpx; margin-top: 8rpx;
}

.btn-register::after { border: none !important; }

/* 链接 */
.links {
  display: flex; justify-content: center;
  align-items: center; gap: 12rpx;
}

.links text {
  font-size: 28rpx; color: rgba(255,255,255,0.4);
}

.link {
  font-size: 28rpx; color: var(--color-accent) !important;
  font-weight: 600;
}
