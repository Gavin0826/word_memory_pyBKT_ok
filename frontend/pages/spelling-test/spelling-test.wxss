/* pages/spelling-test/spelling-test.wxss - Part 1 */

.container {
  min-height: 100vh;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
  padding-bottom: 60rpx;
}

.header {
  background: var(--grad-card);
  padding: 60rpx 40rpx 36rpx;
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -80rpx; right: -60rpx;
  width: 300rpx; height: 300rpx;
  border-radius: 50%;
  background: rgba(245,166,35,0.07);
}

.progress-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  position: relative; z-index: 1;
}

.progress-label {
  font-size: 22rpx; font-weight: 700;
  color: rgba(255,255,255,0.45); letter-spacing: 3rpx;
}

.progress-count {
  font-size: 28rpx; font-weight: 800;
  color: var(--color-accent);
}

.progress-bar-bg {
  height: 8rpx;
  background: rgba(255,255,255,0.12);
  border-radius: 8rpx; overflow: hidden;
  position: relative; z-index: 1;
}

.progress-bar-fill {
  height: 100%;
  background: var(--grad-accent);
  border-radius: 8rpx;
  transition: width 0.4s ease;
}

.main {
  flex: 1; padding: 32rpx;
  display: flex; flex-direction: column; gap: 24rpx;
}

/* 释义提示卡 */
.hint-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 36rpx;
  box-shadow: var(--shadow-sm);
  border-left: 8rpx solid var(--color-accent);
}

.hint-label {
  font-size: 20rpx; font-weight: 700;
  color: var(--color-text-muted); letter-spacing: 2rpx;
  display: block; margin-bottom: 12rpx;
}

.hint-meaning {
  font-size: 36rpx; font-weight: 700;
  color: var(--color-text-primary);
  display: block; margin-bottom: 10rpx; line-height: 1.5;
}

.hint-pron {
  font-size: 26rpx; color: var(--color-accent);
  font-style: italic; display: block;
}

/* 拼写卡 */
.spell-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: var(--shadow-sm);
}

.spell-instruction {
  font-size: 24rpx; color: var(--color-text-muted);
  display: block; margin-bottom: 32rpx; letter-spacing: 1rpx;
}

.word-display {
  display: flex; align-items: baseline;
  justify-content: center; gap: 0;
  margin-bottom: 40rpx; flex-wrap: wrap;
}

.word-shown {
  font-size: 64rpx; font-weight: 900;
  color: var(--color-text-primary);
  letter-spacing: 2rpx; line-height: 1;
}

.blank-wrap { display: flex; align-items: baseline; }

.blank-underline {
  font-size: 64rpx; font-weight: 900;
  color: rgba(200,200,200,0.6);
  letter-spacing: 2rpx;
  border-bottom: 6rpx solid var(--color-accent);
  line-height: 1; min-width: 40rpx;
  text-align: center;
}

.spell-input {
  width: 100%; height: 96rpx;
  background: var(--color-bg);
  border: 3rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 0 32rpx;
  font-size: 44rpx; font-weight: 800;
  color: var(--color-text-primary);
  text-align: center; letter-spacing: 8rpx;
  box-sizing: border-box;
}

.input-correct {
  border-color: var(--color-success) !important;
  background: rgba(62,207,142,0.06) !important;
  color: var(--color-success) !important;
}

.input-wrong {
  border-color: var(--color-danger) !important;
  background: rgba(255,92,92,0.06) !important;
  color: var(--color-danger) !important;
}

.result-feedback {
  margin-top: 28rpx; padding-top: 28rpx;
  border-top: 2rpx solid var(--color-border);
}

.result-row {
  display: flex; align-items: center;
  gap: 16rpx; margin-bottom: 12rpx;
}

.result-icon { font-size: 48rpx; line-height: 1; }

.result-text {
  font-size: 32rpx; font-weight: 800;
  color: var(--color-text-primary);
}

.correct-answer {
  display: flex; align-items: center; gap: 12rpx;
  background: rgba(255,92,92,0.06);
  border-radius: var(--radius-sm);
  padding: 16rpx 20rpx;
}

.ca-label { font-size: 24rpx; color: var(--color-text-muted); }

.ca-word {
  font-size: 36rpx; font-weight: 800;
  color: var(--color-danger);
}

/* 操作按钮 */
.action-area { margin-top: 8rpx; }

.btn-submit {
  width: 100%; height: 100rpx;
  background: var(--grad-accent) !important;
  color: #1a2744 !important;
  font-size: 34rpx; font-weight: 800;
  border-radius: var(--radius-xl) !important;
  border: none !important;
  box-shadow: var(--shadow-accent);
  letter-spacing: 4rpx;
}

.btn-next {
  width: 100%; height: 100rpx;
  background: var(--grad-primary) !important;
  color: #ffffff !important;
  font-size: 34rpx; font-weight: 800;
  border-radius: var(--radius-xl) !important;
  border: none !important;
  box-shadow: var(--shadow-md);
}

.btn-submit::after, .btn-next::after { border: none !important; }

/* 小统计 */
.mini-stats {
  display: flex;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.mini-stat {
  flex: 1; text-align: center;
  padding: 24rpx 0;
  border-right: 2rpx solid var(--color-border);
}

.mini-stat:last-child { border-right: none; }

.mini-val {
  font-size: 44rpx; font-weight: 900;
  display: block; line-height: 1; margin-bottom: 8rpx;
}

.correct-stat .mini-val { color: var(--color-success); }
.wrong-stat .mini-val { color: var(--color-danger); }
.remain-stat .mini-val { color: var(--color-text-primary); }

.mini-lbl {
  font-size: 20rpx; color: var(--color-text-muted); display: block;
}

/* 完成页 */
.finish-view {
  flex: 1; padding: 48rpx 32rpx;
  display: flex; flex-direction: column;
  align-items: center;
}

.finish-icon {
  font-size: 120rpx; display: block;
  margin-bottom: 20rpx; text-align: center;
}

.finish-title {
  font-size: 48rpx; font-weight: 900;
  color: var(--color-text-primary);
  display: block; margin-bottom: 40rpx;
  letter-spacing: 2rpx;
}

.finish-stats {
  display: flex;
  background: var(--color-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  width: 100%;
  margin-bottom: 32rpx;
}

.finish-stat {
  flex: 1; text-align: center;
  padding: 32rpx 0;
}

.fs-value {
  font-size: 56rpx; font-weight: 900;
  display: block; line-height: 1; margin-bottom: 10rpx;
  color: var(--color-text-primary);
}

.fs-value.accent { color: var(--color-success); }
.fs-value.danger { color: var(--color-danger); }

.fs-label {
  font-size: 22rpx; color: var(--color-text-muted); display: block;
}

.fs-divider {
  width: 2rpx; background: var(--color-border);
  margin: 20rpx 0;
}

/* 错词回顾 */
.wrong-review {
  width: 100%;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 32rpx;
}

.wr-title {
  font-size: 24rpx; font-weight: 700;
  color: var(--color-text-muted); letter-spacing: 2rpx;
  display: block; margin-bottom: 20rpx;
}

.wr-item {
  display: flex; align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--color-border);
}

.wr-item:last-child { border-bottom: none; }

.wr-word {
  font-size: 32rpx; font-weight: 800;
  color: var(--color-danger);
}

.wr-meaning {
  font-size: 24rpx; color: var(--color-text-muted);
  flex: 1; text-align: right; margin-left: 16rpx;
}

/* 完成按钮 */
.finish-actions {
  width: 100%;
  display: flex; flex-direction: column; gap: 16rpx;
}

.btn-retry {
  width: 100%; height: 100rpx;
  background: var(--grad-accent) !important;
  color: #1a2744 !important;
  font-size: 32rpx; font-weight: 800;
  border-radius: var(--radius-xl) !important;
  border: none !important;
  box-shadow: var(--shadow-accent);
}

.btn-home {
  width: 100%; height: 88rpx;
  background: transparent !important;
  color: var(--color-text-secondary) !important;
  font-size: 30rpx;
  border: 2rpx solid var(--color-border) !important;
  border-radius: var(--radius-xl) !important;
}

.btn-retry::after, .btn-home::after { border: none !important; }
