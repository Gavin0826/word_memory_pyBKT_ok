/* ==============================
   学习设置页样式
   ============================== */

.container {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 0 32rpx 60rpx;
}

/* 顶部卡片 */
.header-card {
  background: var(--grad-card);
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
  padding: 80rpx 40rpx 56rpx;
  text-align: center;
  margin: 0 -32rpx 32rpx;
  position: relative; overflow: hidden;
}

.header-card::before {
  content: '';
  position: absolute;
  top: -60rpx; right: -60rpx;
  width: 280rpx; height: 280rpx;
  border-radius: 50%;
  background: rgba(245,166,35,0.08);
}

.header-icon { font-size: 80rpx; display: block; margin-bottom: 16rpx; }

.header-title {
  font-size: 48rpx; font-weight: 900;
  color: #ffffff; display: block; margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx; color: rgba(255,255,255,0.45);
  display: block;
}

/* 设置卡片 */
.setting-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 36rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
}

.setting-header {
  display: flex; justify-content: space-between;
  align-items: center; margin-bottom: 24rpx;
}

.setting-label-row {
  display: flex; align-items: center; gap: 16rpx;
}

.setting-icon { font-size: 36rpx; }

.setting-title {
  font-size: 32rpx; font-weight: 700;
  color: var(--color-text-primary);
}

.setting-value-badge {
  display: flex; align-items: baseline; gap: 6rpx;
  background: rgba(245,166,35,0.1);
  padding: 10rpx 24rpx;
  border-radius: var(--radius-lg);
}

.setting-value {
  font-size: 44rpx; font-weight: 900;
  color: var(--color-accent);
}

.setting-unit {
  font-size: 22rpx; color: var(--color-accent);
  opacity: 0.7;
}

/* 滑块 */
.slider-wrap {
  display: flex; align-items: center; gap: 16rpx;
}

.slider-min, .slider-max {
  font-size: 24rpx; color: var(--color-text-muted);
  font-weight: 600; width: 40rpx; text-align: center;
  flex-shrink: 0;
}

.slider { flex: 1; }

/* 提示 */
.setting-tips { margin-top: 20rpx; }

.tip-item {
  font-size: 24rpx; color: var(--color-text-muted);
  display: block; line-height: 1.6;
}

/* 说明卡片 */
.info-card {
  background: rgba(245,166,35,0.06);
  border: 2rpx solid rgba(245,166,35,0.15);
  border-radius: var(--radius-lg);
  padding: 32rpx 36rpx;
  margin-bottom: 32rpx;
}

.info-title {
  font-size: 28rpx; font-weight: 700;
  color: var(--color-text-primary);
  display: block; margin-bottom: 20rpx;
}

.info-item {
  font-size: 24rpx; color: var(--color-text-secondary);
  display: block; line-height: 1.8; margin-bottom: 8rpx;
}

/* 操作按钮 */
.actions {
  display: flex; flex-direction: column; gap: 16rpx;
}

.btn-save {
  width: 100%; height: 100rpx;
  background: var(--grad-accent) !important;
  color: #1a2744 !important;
  font-size: 34rpx; font-weight: 800;
  border-radius: var(--radius-xl) !important;
  border: none !important;
  box-shadow: var(--shadow-accent);
  letter-spacing: 2rpx;
}

.btn-reset {
  width: 100%; height: 88rpx;
  background: transparent !important;
  color: var(--color-text-secondary) !important;
  font-size: 30rpx; font-weight: 600;
  border: 2rpx solid var(--color-border) !important;
  border-radius: var(--radius-xl) !important;
}

.btn-save::after, .btn-reset::after { border: none !important; }
