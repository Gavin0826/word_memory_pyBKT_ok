/* ==============================
   词库选择页样式
   ============================== */

.container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 48rpx;
}

/* 顶部 Header */
.header {
  background: var(--grad-card);
  padding: 80rpx 40rpx 50rpx;
  position: relative;
  overflow: hidden;
}

.header::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(245, 166, 35, 0.07);
}

.header-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
  letter-spacing: 3rpx;
  display: block;
  margin-bottom: 12rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 900;
  color: #ffffff;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
  display: block;
}

/* 词库列表 */
.category-list {
  padding: 32rpx 32rpx 0;
}

.list-label {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--color-text-muted);
  letter-spacing: 3rpx;
  margin-bottom: 20rpx;
  display: block;
}

/* 词库卡片 */
.category-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
  transition: transform 0.15s, box-shadow 0.15s;
}

.category-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.category-card.cet4::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 8rpx;
  background: var(--grad-accent);
}

.category-card.cet6::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 8rpx;
  background: var(--grad-success);
}

.category-card.kaoyan::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 8rpx;
  background: linear-gradient(135deg, #a855f7, #7c3aed);
}

.card-content {
  flex: 1;
  padding-left: 24rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  letter-spacing: 1rpx;
}

.category-count {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-accent);
  background: rgba(245, 166, 35, 0.1);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
}

.category-desc {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.card-arrow {
  font-size: 48rpx;
  color: var(--color-text-muted);
  font-weight: 300;
  margin-left: 16rpx;
}

/* 底部操作区 */
.footer {
  padding: 24rpx 32rpx 48rpx;
}

.footer-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 收藏夹入口 */
.favorite-entry {
  display: flex;
  align-items: center;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 36rpx;
  box-shadow: var(--shadow-sm);
  gap: 20rpx;
  border: 2rpx solid rgba(245,166,35,0.2);
}

.favorite-entry-icon {
  font-size: 40rpx;
  color: var(--color-accent);
  line-height: 1;
}

.favorite-entry-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  flex: 1;
}

.favorite-entry-count {
  background: var(--grad-accent);
  color: #1a2744;
  font-size: 22rpx;
  font-weight: 800;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-accent);
}

/* 返回按钮 */
.btn-back {
  width: 100%; height: 88rpx;
  background: transparent !important;
  color: var(--color-text-secondary) !important;
  font-size: 30rpx;
  border: 2rpx solid var(--color-border) !important;
  border-radius: var(--radius-xl) !important;
}

.btn-back::after { border: none !important; }
